# API Key (required)
LLM_API_KEY=your-api-key
# Model ID (required)
MODEL_ID=your-model-id
# Base URL (optional for anthropic models; required for other anthropic-compatible providers or local proxy/router, claude-code-router as example)
LLM_BASE_URL=your-llm-provider-url
# Status pane refresh interval in seconds (default: 1.0)
# Set to 0 to disable the status pane
LIBERCODE_STATUS_REFRESH=5.0
